        {
          "name": "POST /api/auth/login (Super Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login_id\": \"superadmin\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "if (Array.isArray(body) && body[0] && body[0].token) { pm.collectionVariables.set('token', body[0].token); }",
                  "if (Array.isArray(body) && body[0] && body[0].user && body[0].user.user_id) { pm.collectionVariables.set('userId', body[0].user.user_id); }"
                ]
              }
            }
          ]
        },
